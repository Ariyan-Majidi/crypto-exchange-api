{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CoinMarketCapSettings": {
    "BaseUrl": "https://pro-api.coinmarketcap.com/",
    "ApiKey": "APIKEY"
  },
  "ExchangeRatesSettings": {
    "BaseUrl": "http://api.exchangeratesapi.io/v1/",
    "ApiKey": "APIKEY",
    "Symbols": "USD,BRL,GBP,AUD"
  },
  "CacheSettings": {
    "ExchangeRates": {
      "FreshnessTtlHours": 8,
      "AbsoluteExpirationHours": 48,
      "EnableCaching": true
    },
    "CoinMarketCap": {
      "FreshnessTtlMinutes": 15,
      "AbsoluteExpirationHours": 24,
      "EnableCaching": true
    }
  }
}